<UserControl x:Class="NarrativeForge.App.Controls.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Surface1}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="VERSION HISTORY" FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>

        <!-- Action Buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,4,12,8">
            <Button Content="Create Snapshot" Padding="10,4" Margin="0,0,6,0"
                    Background="{DynamicResource Teal}" Foreground="{DynamicResource Base}"
                    Click="CreateSnapshot_Click" FontSize="11"/>
            <Button x:Name="RestoreButton" Content="Restore" Padding="10,4" Margin="0,0,6,0"
                    Background="{DynamicResource Blue}" Foreground="{DynamicResource Base}"
                    Click="Restore_Click" FontSize="11" IsEnabled="False"/>
            <Button x:Name="CompareButton" Content="Compare" Padding="10,4"
                    Background="{DynamicResource Surface2}" Foreground="{DynamicResource Text}"
                    Click="Compare_Click" FontSize="11" IsEnabled="False"/>
        </StackPanel>

        <!-- Timeline -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="VersionsList" Margin="12,0,12,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Ellipse Grid.Column="0" Grid.RowSpan="2" Width="10" Height="10"
                                     Fill="{DynamicResource Blue}" VerticalAlignment="Center"
                                     Margin="7,0,7,0"/>
                            <Rectangle Grid.Column="0" Grid.Row="1" Width="2" Fill="{DynamicResource Surface2}"
                                       VerticalAlignment="Stretch" HorizontalAlignment="Center"
                                       Margin="11,0,11,0"/>

                            <Border Grid.Column="1" Background="{DynamicResource Surface0}"
                                    CornerRadius="6" Padding="10,8" Cursor="Hand"
                                    MouseLeftButtonDown="VersionCard_Click" Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource Text}"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                   FontSize="10" Foreground="{DynamicResource Subtext0}" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{DynamicResource Overlay1}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <CheckBox x:Name="FromCheck" Content="From" FontSize="10"
                                                  Foreground="{DynamicResource Subtext1}" Margin="0,0,0,2"
                                                  Checked="FromCheck_Changed" Unchecked="FromCheck_Changed"/>
                                        <CheckBox x:Name="ToCheck" Content="To" FontSize="10"
                                                  Foreground="{DynamicResource Subtext1}"
                                                  Checked="ToCheck_Changed" Unchecked="ToCheck_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Surface0}" Padding="12,6">
            <TextBlock x:Name="StatusTextBlock" Text="Ready" FontSize="11" Foreground="{DynamicResource Subtext1}"/>
        </Border>

        <!-- Empty State -->
        <TextBlock x:Name="EmptyState"
                   Text="No versions yet. Create a snapshot to start tracking history."
                   FontSize="11" Foreground="{DynamicResource Overlay1}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="12"/>
    </DockPanel>
</UserControl>
