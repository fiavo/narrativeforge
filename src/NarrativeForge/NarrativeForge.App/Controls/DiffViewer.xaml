<UserControl x:Class="NarrativeForge.App.Controls.DiffViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Surface1}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="DIFF VIEWER" FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>

        <!-- Header: Version Labels -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Surface0}" Padding="12,8" Margin="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FromVersionLabel" Text="From Version"
                           FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource Text}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="vs" FontSize="11"
                           Foreground="{DynamicResource Overlay1}" VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="ToVersionLabel" Text="To Version"
                           FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource Text}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Summary Stats -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Surface0}" Padding="12,6" Margin="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Background="#30a6e3a1" CornerRadius="4" Padding="8,2" Margin="0,0,8,0">
                    <TextBlock x:Name="AddedCount" Text="0 added" FontSize="11" Foreground="{DynamicResource Teal}"/>
                </Border>
                <Border Background="#30f38ba8" CornerRadius="4" Padding="8,2" Margin="0,0,8,0">
                    <TextBlock x:Name="RemovedCount" Text="0 removed" FontSize="11" Foreground="{DynamicResource Red}"/>
                </Border>
                <Border Background="#30f9e2af" CornerRadius="4" Padding="8,2">
                    <TextBlock x:Name="ModifiedCount" Text="0 modified" FontSize="11" Foreground="{DynamicResource Yellow}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,8,12,8">
            <Button x:Name="RestoreButton" Content="Restore To Version" Padding="10,4" Margin="0,0,6,0"
                    Background="{DynamicResource Blue}" Foreground="{DynamicResource Base}"
                    Click="Restore_Click" FontSize="11" IsEnabled="False"/>
            <Button Content="Clear" Padding="10,4"
                    Background="{DynamicResource Surface2}" Foreground="{DynamicResource Text}"
                    Click="Clear_Click" FontSize="11"/>
        </StackPanel>

        <!-- Diff Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="DiffGroupsList" ItemsSource="{Binding DiffGroups}" Margin="12,0,12,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Background="Transparent">
                            <StackPanel>
                                <!-- Entity Type Group Header -->
                                <Border Background="{DynamicResource Surface0}" CornerRadius="6"
                                        Padding="10,6" Margin="0,0,0,4" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding EntityType}" FontWeight="Bold" FontSize="12"
                                                   Foreground="{DynamicResource Mauve}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ChangeCount, StringFormat='({0} changes)'}"
                                                   FontSize="11" Foreground="{DynamicResource Subtext1}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Change Items -->
                                <ItemsControl ItemsSource="{Binding Changes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,2"
                                                    Background="{Binding ChangeBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Change Type Badge -->
                                                    <Border Grid.Column="0" CornerRadius="3" Padding="6,2"
                                                            Margin="0,0,10,0" VerticalAlignment="Center"
                                                            Background="{Binding BadgeBrush}">
                                                        <TextBlock Text="{Binding ChangeTypeLabel}" FontSize="9"
                                                                   FontWeight="Bold" Foreground="{DynamicResource Base}"/>
                                                    </Border>

                                                    <!-- Content -->
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding PropertyName}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                                        <TextBlock FontSize="10" Foreground="{DynamicResource Subtext0}"
                                                                   Text="{Binding OldValue}"/>
                                                        <TextBlock Text=" → " FontSize="10"
                                                                   Foreground="{DynamicResource Overlay0}"/>
                                                        <TextBlock FontSize="10" Foreground="{DynamicResource Subtext0}"
                                                                   Text="{Binding NewValue}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Surface0}" Padding="12,6">
            <TextBlock x:Name="StatusTextBlock" Text="Select two versions in History to compare."
                       FontSize="11" Foreground="{DynamicResource Subtext1}"/>
        </Border>

        <!-- Empty State -->
        <TextBlock x:Name="EmptyState"
                   Text="No differences to display. Select two versions and click Compare."
                   FontSize="11" Foreground="{DynamicResource Overlay1}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="12"/>
    </DockPanel>
</UserControl>
