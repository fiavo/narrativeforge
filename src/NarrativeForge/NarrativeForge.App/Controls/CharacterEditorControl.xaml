<UserControl x:Class="NarrativeForge.App.Controls.CharacterEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Surface1}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="CHARACTER EDITOR" FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>

        <TextBlock x:Name="EmptyState" DockPanel.Dock="Top" Text="Select a character to edit"
                   FontSize="11" Foreground="{DynamicResource Overlay1}" Margin="12,4,12,0"
                   Visibility="Visible"/>

        <ScrollViewer x:Name="EditorScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"
                      Visibility="Collapsed">
            <StackPanel x:Name="EditorPanel" Margin="0">

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,4,12,8">
                    <StackPanel>
                        <TextBlock Text="Name" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NameTextBox"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Role" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="RoleComboBox"
                                  Foreground="{DynamicResource Text}"
                                  Background="{DynamicResource Surface1}"
                                  SelectionChanged="RoleComboBox_SelectionChanged">
                            <ComboBoxItem Content="Protagonist"/>
                            <ComboBoxItem Content="Antagonist"/>
                            <ComboBoxItem Content="Deuteragonist"/>
                            <ComboBoxItem Content="Sidekick"/>
                            <ComboBoxItem Content="Mentor"/>
                            <ComboBoxItem Content="LoveInterest"/>
                            <ComboBoxItem Content="ComicRelief"/>
                            <ComboBoxItem Content="Trickster"/>
                            <ComboBoxItem Content="Supporting"/>
                            <ComboBoxItem Content="Background"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Personality Traits" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TraitsTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="12"
                                 ToolTip="One trait per line"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Backstory" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="BackstoryTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Motivation" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="MotivationTextBox"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Goals" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="GoalsTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="12"
                                 ToolTip="One goal per line"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Fears" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="FearsTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="12"
                                 ToolTip="One fear per line"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Dialogue Style" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="DialogueStyleTextBox"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="AppearanceTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="IsAliveCheckBox"
                                  Content="Is Alive" FontSize="12"
                                  Foreground="{DynamicResource Text}"
                                  VerticalAlignment="Center"/>
                        <CheckBox x:Name="IsLockedCheckBox"
                                  Content="Is Locked" FontSize="12" Margin="20,0,0,0"
                                  Foreground="{DynamicResource Text}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
