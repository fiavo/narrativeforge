<UserControl x:Class="NarrativeForge.App.Controls.PropertyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NarrativeForge.App.ViewModels"
             Background="{DynamicResource Surface1}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Panel Header -->
        <TextBlock DockPanel.Dock="Top" Text="PROPERTIES" FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>

        <!-- Empty State -->
        <TextBlock x:Name="EmptyState" DockPanel.Dock="Top" Text="Select a node to view properties"
                   FontSize="11" Foreground="{DynamicResource Overlay1}" Margin="12,4,12,0"
                   Visibility="Visible"/>

        <!-- Properties Content -->
        <ScrollViewer x:Name="PropScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"
                      Visibility="Collapsed">
            <StackPanel x:Name="PropPanel" Margin="0">

                <!-- Common Fields Section -->
                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,4,12,8">
                    <StackPanel>
                        <TextBlock Text="Node Type" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="NodeTypeComboBox" SelectedIndex="0"
                                  Foreground="{DynamicResource Text}"
                                  Background="{DynamicResource Surface1}"
                                  SelectionChanged="NodeTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="text"/>
                            <ComboBoxItem Content="choice"/>
                            <ComboBoxItem Content="condition"/>
                            <ComboBoxItem Content="variable"/>
                            <ComboBoxItem Content="jump"/>
                            <ComboBoxItem Content="end"/>
                            <ComboBoxItem Content="start"/>
                            <ComboBoxItem Content="objective"/>
                            <ComboBoxItem Content="reward"/>
                            <ComboBoxItem Content="fail"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Title" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TitleTextBox"
                                 Text="{Binding SelectedNode.Title, ElementName=PropPanel, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Content" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBox x:Name="ContentTextBox"
                                 Text="{Binding SelectedNode.Content, ElementName=PropPanel, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                                 Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                                 BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Choices Section (dialogue types) -->
                <Border x:Name="ChoicesSection" Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Choices" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Subtext1}" VerticalAlignment="Center"/>
                            <Button Content="+" HorizontalAlignment="Right" Padding="6,2"
                                    Background="{DynamicResource Surface2}" Foreground="{DynamicResource Text}"
                                    Click="AddChoice_Click" FontSize="14" FontWeight="Bold"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding SelectedNode.Choices, ElementName=PropPanel}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Surface1}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                        <StackPanel>
                                            <TextBlock Text="Text" FontSize="10" Foreground="{DynamicResource Overlay1}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                                     BorderBrush="{DynamicResource Surface2}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock Text="Condition" FontSize="10" Foreground="{DynamicResource Overlay1}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                                     BorderBrush="{DynamicResource Surface2}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock Text="Next Node ID" FontSize="10" Foreground="{DynamicResource Overlay1}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding NextNodeId, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                                     BorderBrush="{DynamicResource Surface2}" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Objectives Section (quest types) -->
                <Border x:Name="ObjectivesSection" Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Objectives" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Subtext1}" VerticalAlignment="Center"/>
                            <Button Content="+" HorizontalAlignment="Right" Padding="6,2"
                                    Background="{DynamicResource Surface2}" Foreground="{DynamicResource Text}"
                                    Click="AddObjective_Click" FontSize="14" FontWeight="Bold"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding SelectedNode.Objectives, ElementName=PropPanel}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Surface1}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                        <StackPanel>
                                            <TextBlock Text="Description" FontSize="10" Foreground="{DynamicResource Overlay1}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                                     BorderBrush="{DynamicResource Surface2}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock Text="Type" FontSize="10" Foreground="{DynamicResource Overlay1}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                                     BorderBrush="{DynamicResource Surface2}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock Text="Target" FontSize="10" Foreground="{DynamicResource Overlay1}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                                     BorderBrush="{DynamicResource Surface2}" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Node ID (read-only) -->
                <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="12,0,12,8">
                    <StackPanel>
                        <TextBlock Text="Node ID" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedNode.Id, ElementName=PropPanel}"
                                   FontSize="10" Foreground="{DynamicResource Overlay1}"
                                   FontFamily="Cascadia Mono, Consolas"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
