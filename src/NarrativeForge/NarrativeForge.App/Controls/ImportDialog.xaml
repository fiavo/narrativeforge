<Window x:Class="NarrativeForge.App.Controls.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface0}"
        Foreground="{DynamicResource Text}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File Picker & Format -->
        <Border Grid.Row="0" Background="{DynamicResource Surface1}" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding SelectedFilePath, FallbackValue='No file selected'}"
                           VerticalAlignment="Center" Foreground="{DynamicResource Text}"
                           TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="1" Content="Browse..." Padding="12,6"
                        Background="{DynamicResource Surface2}" Foreground="{DynamicResource Text}"
                        Click="Browse_Click"/>

                <TextBlock Grid.Column="3" Text="FORMAT" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource Subtext1}" VerticalAlignment="Center"/>

                <ComboBox Grid.Column="4" ItemsSource="{Binding AvailableFormats}"
                          SelectedItem="{Binding SelectedFormat}"
                          MinWidth="160" Padding="8,6" Margin="8,0,0,0"
                          Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                          BorderBrush="{DynamicResource Surface2}"/>
            </Grid>
        </Border>

        <!-- File Info -->
        <Border Grid.Row="1" Background="{DynamicResource Surface1}" CornerRadius="6" Padding="12" Margin="0,0,0,10"
                Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="File: " Foreground="{DynamicResource Subtext1}" FontSize="11"/>
                <TextBlock Text="{Binding SelectedFilePath}" Foreground="{DynamicResource Text}" FontSize="11"/>
                <TextBlock Text="  |  Size: " Foreground="{DynamicResource Subtext1}" FontSize="11"/>
                <TextBlock Text="{Binding FileSizeDisplay}" Foreground="{DynamicResource Text}" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Preview Pane -->
        <Border Grid.Row="2" Background="{DynamicResource Surface0}" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                BorderBrush="{DynamicResource Surface2}" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="PREVIEW" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6"/>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding IsFileLoaded, Converter={StaticResource InvertBool}}">
                        <TextBlock Text="Select a file to preview its contents"
                                   Foreground="{DynamicResource Subtext0}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding PreviewContent}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource Text}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{DynamicResource Subtext0}"
                   FontSize="12" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8" Margin="0,0,8,0"
                    Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"/>
            <Button Content="Import" Command="{Binding ImportCommand}" Padding="16,8"
                    Background="{DynamicResource Teal}" Foreground="{DynamicResource Base}"
                    IsEnabled="{Binding IsFileLoaded}"/>
        </StackPanel>
    </Grid>
</Window>
