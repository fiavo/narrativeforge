<UserControl x:Class="NarrativeForge.App.Controls.RelationshipPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NarrativeForge.App.Controls"
             Background="{DynamicResource Surface1}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="RELATIONSHIPS" FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>

        <TextBlock x:Name="EmptyState" DockPanel.Dock="Top" Text="Select a character to view relationships"
                   FontSize="11" Foreground="{DynamicResource Overlay1}" Margin="12,4,12,0"
                   Visibility="Visible"/>

        <StackPanel x:Name="ContentPanel" DockPanel.Dock="Top" Visibility="Collapsed" Margin="0,0,0,0">

            <!-- Mini Graph Visualization -->
            <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="4" Margin="12,4,12,8">
                <Border Height="180" ClipToBounds="True">
                    <controls:GraphCanvas x:Name="MiniGraphCanvas"
                                          Nodes="{Binding MiniNodes}"
                                          Edges="{Binding MiniEdges}"
                                          Background="{DynamicResource Surface0}"/>
                </Border>
            </Border>

            <!-- Relationship List Header -->
            <DockPanel Margin="12,0,12,4">
                <TextBlock Text="Connected Entities" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Subtext1}" VerticalAlignment="Center"/>
                <Button x:Name="AddRelationshipButton" Content="+ Add" HorizontalAlignment="Right"
                        Padding="8,3" Background="{DynamicResource Blue}" Foreground="{DynamicResource Base}"
                        Click="AddRelationship_Click" FontSize="11"/>
            </DockPanel>

            <!-- Relationship List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,0,12,12">
                <ItemsControl x:Name="RelationshipItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Surface0}" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding EntityName}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding RelationshipType}" FontSize="11"
                                                   Foreground="{DynamicResource Subtext0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="x" Padding="4,1"
                                            Background="Transparent" Foreground="{DynamicResource Red}"
                                            FontSize="11" FontWeight="Bold" Cursor="Hand"
                                            Tag="{Binding EntityId}"
                                            Click="RemoveRelationship_Click"
                                            VerticalAlignment="Top"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Add Relationship Dialog (initially hidden) -->
        <Border x:Name="AddDialog" DockPanel.Dock="Top" Background="{DynamicResource Surface0}"
                CornerRadius="6" Padding="12" Margin="12,4,12,8" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="New Relationship" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}" Margin="0,0,0,8"/>
                <TextBlock Text="Target Character" FontSize="10" Foreground="{DynamicResource Subtext1}" Margin="0,0,0,2"/>
                <ComboBox x:Name="TargetCharacterComboBox" Margin="0,0,0,8"
                          Foreground="{DynamicResource Text}" Background="{DynamicResource Surface1}"/>
                <TextBlock Text="Relationship Type" FontSize="10" Foreground="{DynamicResource Subtext1}" Margin="0,0,0,2"/>
                <ComboBox x:Name="RelationshipTypeComboBox" Margin="0,0,0,8"
                          Foreground="{DynamicResource Text}" Background="{DynamicResource Surface1}">
                    <ComboBoxItem Content="Friend"/>
                    <ComboBoxItem Content="Rival"/>
                    <ComboBoxItem Content="Ally"/>
                    <ComboBoxItem Content="Enemy"/>
                    <ComboBoxItem Content="Mentor"/>
                    <ComboBoxItem Content="Student"/>
                    <ComboBoxItem Content="Family"/>
                    <ComboBoxItem Content="Romantic"/>
                    <ComboBoxItem Content="Leader"/>
                    <ComboBoxItem Content="Follower"/>
                    <ComboBoxItem Content="Neutral"/>
                    <ComboBoxItem Content="Custom"/>
                </ComboBox>
                <TextBlock x:Name="CustomTypeLabel" Text="Custom Type" FontSize="10"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,2" Visibility="Collapsed"/>
                <TextBox x:Name="CustomTypeTextBox" Margin="0,0,0,8" Visibility="Collapsed"
                         Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"
                         BorderBrush="{DynamicResource Surface2}" FontSize="12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Confirm" Padding="12,4" Margin="0,0,8,0"
                            Background="{DynamicResource Teal}" Foreground="{DynamicResource Base}"
                            Click="ConfirmAddRelationship_Click"/>
                    <Button Content="Cancel" Padding="12,4"
                            Background="{DynamicResource Surface2}" Foreground="{DynamicResource Text}"
                            Click="CancelAddRelationship_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
