<Window x:Class="NarrativeForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NarrativeForge.App.ViewModels"
        xmlns:controls="clr-namespace:NarrativeForge.App.Controls"
        Title="NarrativeForge" Height="720" Width="1280"
        Background="{DynamicResource Surface0}"
        Foreground="{DynamicResource Text}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InvertBoolConverter x:Key="InvertBool"
            xmlns:local="clr-namespace:NarrativeForge.App"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding GraphEditorViewModel.LayoutLastUsedCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}">
            <MenuItem Header="_Project" Foreground="{DynamicResource Text}">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" Foreground="{DynamicResource Text}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuItem_Exit_Click" Foreground="{DynamicResource Text}"/>
            </MenuItem>
            <MenuItem Header="_Generate" Foreground="{DynamicResource Text}">
                <MenuItem Header="_Run Generation" Command="{Binding GenerateCommand}" Foreground="{DynamicResource Text}"/>
            </MenuItem>
            <MenuItem Header="_Graph" Foreground="{DynamicResource Text}">
                <MenuItem Header="_New Dialogue Tree" Command="{Binding OpenDialogueTreeCommand}" Foreground="{DynamicResource Text}"/>
                <MenuItem Header="_New Quest Graph" Command="{Binding OpenQuestGraphCommand}" Foreground="{DynamicResource Text}"/>
                <Separator/>
                <MenuItem Header="_Auto Layout" Foreground="{DynamicResource Text}">
                    <MenuItem Header="_Hierarchical" Command="{Binding GraphEditorViewModel.LayoutHierarchicalCommand}" Foreground="{DynamicResource Text}"/>
                    <MenuItem Header="_Force-Directed" Command="{Binding GraphEditorViewModel.LayoutForceDirectedCommand}" Foreground="{DynamicResource Text}"/>
                    <Separator/>
                    <MenuItem Header="_Last Used (Ctrl+L)" Command="{Binding GraphEditorViewModel.LayoutLastUsedCommand}" Foreground="{DynamicResource Text}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Story Bible" Foreground="{DynamicResource Text}">
                <MenuItem Header="_Open Story Bible" Command="{Binding OpenStoryBibleCommand}" Foreground="{DynamicResource Text}"/>
            </MenuItem>
            <MenuItem Header="_Version" Foreground="{DynamicResource Text}">
                <MenuItem Header="Create _Snapshot" Command="{Binding HistoryViewModel.CreateSnapshotCommand}" Foreground="{DynamicResource Text}"/>
                <Separator/>
                <MenuItem Header="View _History" Click="ViewHistory_Click" Foreground="{DynamicResource Text}"/>
            </MenuItem>
            <MenuItem Header="_View" Foreground="{DynamicResource Text}">
                <MenuItem Header="_Connect to Backend" Command="{Binding ConnectCommand}" Foreground="{DynamicResource Text}"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource Surface1}" Foreground="{DynamicResource Subtext0}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource Red}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource Green}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Subtext0}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Project Explorer -->
            <Border Grid.Column="0" Background="{DynamicResource Surface1}" BorderBrush="{DynamicResource Surface2}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PROJECT EXPLORER" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,0,12,8">
                        <Button Content="New" Command="{Binding NewProjectCommand}" Margin="0,0,4,0" Padding="10,4"
                                Background="{DynamicResource Blue}" Foreground="{DynamicResource Base}"/>
                        <Button Content="Delete" Command="{Binding DeleteProjectCommand}" Padding="10,4"
                                Background="{DynamicResource Red}" Foreground="{DynamicResource Base}"
                                IsEnabled="{Binding SelectedProject, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                IsHitTestVisible="{Binding SelectedProject, Converter={StaticResource InvertBool}}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource Text}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                    <TextBlock Text="{Binding Genre}" FontSize="11" Foreground="{DynamicResource Subtext0}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource Surface2}"/>

            <!-- Center: Tab Control -->
            <TabControl Grid.Column="2" Background="Transparent" Foreground="{DynamicResource Text}">
                <!-- Generation Tab -->
                <TabItem Header="Generation">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Selected Project Info -->
                        <Border Grid.Row="0" Background="{DynamicResource Surface1}" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="SELECTED PROJECT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6"/>
                                <StackPanel DataContext="{Binding SelectedProject}">
                                    <TextBlock Text="{Binding Name, FallbackValue='No project selected'}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                                    <TextBlock Foreground="{DynamicResource Subtext0}" Margin="0,2,0,0">
                                        <Run Text="{Binding Genre, Mode=OneWay}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Tone, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Output Display -->
                        <Border Grid.Row="1" Background="{DynamicResource Surface0}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="OUTPUT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding GenerationOutput}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Input Area -->
                        <Border Grid.Row="2" Background="{DynamicResource Surface1}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="REQUEST" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding GenerationRequest, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                         Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                                         BorderBrush="{DynamicResource Surface2}" FontSize="13"/>
                            </DockPanel>
                        </Border>

                        <!-- Generate Button + Temperature -->
                        <Grid Grid.Row="3" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Generate" Command="{Binding GenerateCommand}"
                                    Padding="20,8" FontWeight="Bold"
                                    Background="{DynamicResource Mauve}" Foreground="{DynamicResource Base}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Temperature:" Foreground="{DynamicResource Subtext0}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Temperature, StringFormat=F1}" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Width="28"/>
                                <Slider Width="120" Minimum="0" Maximum="2" TickFrequency="0.1"
                                        Value="{Binding Temperature}" VerticalAlignment="Center"
                                        Foreground="{DynamicResource Mauve}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Graph Editor Tab -->
                <TabItem Header="Graph Editor">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Graph List Panel -->
                        <Border Grid.Column="0" Background="{DynamicResource Surface1}" BorderBrush="{DynamicResource Surface2}" BorderThickness="0,0,1,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="GRAPHS" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>
                                <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="12,0,12,8">
                                    <Button Content="New Dialogue Tree" Command="{Binding OpenDialogueTreeCommand}" Margin="0,0,0,4" Padding="10,4"
                                            Background="{DynamicResource Blue}" Foreground="{DynamicResource Base}"/>
                                    <Button Content="New Quest Graph" Command="{Binding OpenQuestGraphCommand}" Padding="10,4"
                                            Background="{DynamicResource Teal}" Foreground="{DynamicResource Base}"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="12,4,12,0">
                                    <TextBlock Text="Current Graph" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Subtext1}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GraphEditorViewModel.GraphName, FallbackValue='No graph loaded'}"
                                               FontSize="12" Foreground="{DynamicResource Text}" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource Subtext0}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Clean"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GraphEditorViewModel.IsDirty}" Value="True">
                                                        <Setter Property="Text" Value="Unsaved changes"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Yellow}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,12">
                                    <TextBlock Text="Nodes: " FontSize="10" Foreground="{DynamicResource Subtext1}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding GraphEditorViewModel.Nodes.Count}" FontSize="10" Foreground="{DynamicResource Subtext0}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Edges: " FontSize="10" Foreground="{DynamicResource Subtext1}" HorizontalAlignment="Left" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding GraphEditorViewModel.Edges.Count}" FontSize="10" Foreground="{DynamicResource Subtext0}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Surface2}"/>

                        <!-- Graph Canvas -->
                        <Border Grid.Column="2" Background="{DynamicResource Surface0}" CornerRadius="6" Padding="4" Margin="4">
                            <controls:GraphCanvas
                                Nodes="{Binding GraphEditorViewModel.Nodes}"
                                Edges="{Binding GraphEditorViewModel.Edges}"
                                SelectedNode="{Binding GraphEditorViewModel.SelectedNode, Mode=TwoWay}"
                                Background="{DynamicResource Surface0}"/>
                        </Border>

                        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Surface2}"/>

                        <!-- Property Panel -->
                        <Border Grid.Column="4" Background="{DynamicResource Surface1}" BorderBrush="{DynamicResource Surface2}" BorderThickness="1,0,0,0">
                            <controls:PropertyPanel SelectedNode="{Binding GraphEditorViewModel.SelectedNode, Mode=TwoWay}"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Story Bible Tab -->
                <TabItem Header="Story Bible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel: Entity List -->
                        <Border Grid.Column="0" Background="{DynamicResource Surface1}" BorderBrush="{DynamicResource Surface2}" BorderThickness="0,0,1,0">
                            <controls:EntityListControl/>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Surface2}"/>

                        <!-- Center: Editor Controls -->
                        <TabControl Grid.Column="2" Background="Transparent" Foreground="{DynamicResource Text}">
                            <TabItem Header="Character">
                                <controls:CharacterEditorControl/>
                            </TabItem>
                            <TabItem Header="Location">
                                <controls:LocationEditorControl/>
                            </TabItem>
                            <TabItem Header="Faction">
                                <controls:FactionEditorControl/>
                            </TabItem>
                            <TabItem Header="Timeline">
                                <controls:TimelineEditorControl/>
                            </TabItem>
                            <TabItem Header="Lore">
                                <controls:LoreEditorControl/>
                            </TabItem>
                        </TabControl>

                        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Surface2}"/>

                        <!-- Right Panel: Relationships -->
                        <Border Grid.Column="4" Background="{DynamicResource Surface1}" BorderBrush="{DynamicResource Surface2}" BorderThickness="1,0,0,0">
                            <controls:RelationshipPanel/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Version History Tab -->
                <TabItem x:Name="HistoryTab" Header="History">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- History Panel -->
                        <controls:HistoryPanel Grid.Column="0" x:Name="HistoryPanelControl"/>

                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Surface2}"/>

                        <!-- Diff Viewer -->
                        <controls:DiffViewer Grid.Column="2" x:Name="DiffViewerControl"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource Surface2}"/>

            <!-- Right Panel: AI Pipeline -->
            <Border Grid.Column="4" Background="{DynamicResource Surface1}" BorderBrush="{DynamicResource Surface2}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="AI PIPELINE" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource Subtext1}" Margin="12,10,12,6"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,0,12,12">
                        <StackPanel>
                            <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Pipeline Stages" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Margin="0,0,0,8"/>
                                    <TextBlock Text="1. Director Agent" Foreground="{DynamicResource Subtext0}" Margin="0,2"/>
                                    <TextBlock Text="2. Story Agent" Foreground="{DynamicResource Subtext0}" Margin="0,2"/>
                                    <TextBlock Text="3. Consistency Checker" Foreground="{DynamicResource Subtext0}" Margin="0,2"/>
                                    <TextBlock Text="4. Graph Store Update" Foreground="{DynamicResource Subtext0}" Margin="0,2"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource Surface0}" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Connection" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Backend: localhost:8000" Foreground="{DynamicResource Subtext0}" Margin="0,2"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Status: " Foreground="{DynamicResource Subtext0}"/>
                                        <TextBlock Foreground="{DynamicResource Green}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Disconnected"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Red}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Text" Value="Connected"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="0,10,0,0"
                                            Padding="12,6" Background="{DynamicResource Teal}" Foreground="{DynamicResource Base}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
