<Window x:Class="NarrativeForge.App.Export.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NarrativeForge.App.ViewModels"
        Title="Export" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface0}"
        Foreground="{DynamicResource Text}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Format Selector -->
        <Border Grid.Row="0" Background="{DynamicResource Surface1}" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="FORMAT" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource Subtext1}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox ItemsSource="{Binding Exporters}"
                          SelectedItem="{Binding SelectedExporter}"
                          DisplayMemberPath="Name"
                          MinWidth="200" Padding="8,6"
                          Background="{DynamicResource Surface0}" Foreground="{DynamicResource Text}"
                          BorderBrush="{DynamicResource Surface2}"/>
            </DockPanel>
        </Border>

        <!-- Exporter Description -->
        <Border Grid.Row="1" Background="{DynamicResource Surface1}" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding SelectedExporter.Description, FallbackValue=''}"
                           Foreground="{DynamicResource Subtext0}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Extension: " Foreground="{DynamicResource Subtext1}" FontSize="11"/>
                    <TextBlock Text="{Binding SelectedExporter.FileExtension, FallbackValue=''}"
                               Foreground="{DynamicResource Text}" FontSize="11"/>
                    <TextBlock Text="  |  Category: " Foreground="{DynamicResource Subtext1}" FontSize="11"/>
                    <TextBlock Text="{Binding SelectedExporter.Category, FallbackValue=''}"
                               Foreground="{DynamicResource Text}" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Preview Pane -->
        <Border Grid.Row="2" Background="{DynamicResource Surface0}" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                BorderBrush="{DynamicResource Surface2}" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="PREVIEW" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Generating preview..." Foreground="{DynamicResource Subtext0}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsExporting, Converter={StaticResource InvertBool}}">
                        <TextBlock Text="{Binding PreviewContent}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource Text}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{DynamicResource Subtext0}"
                   FontSize="12" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8" Margin="0,0,8,0"
                    Background="{DynamicResource Surface1}" Foreground="{DynamicResource Text}"/>
            <Button Content="Copy to Clipboard" Command="{Binding CopyToClipboardCommand}" Padding="16,8" Margin="0,0,8,0"
                    Background="{DynamicResource Teal}" Foreground="{DynamicResource Base}"
                    IsEnabled="{Binding IsExporting, Converter={StaticResource InvertBool}}"/>
            <Button Content="Save to File" Padding="16,8"
                    Background="{DynamicResource Blue}" Foreground="{DynamicResource Base}"
                    IsEnabled="{Binding IsExporting, Converter={StaticResource InvertBool}}"
                    Click="SaveToFile_Click"/>
        </StackPanel>
    </Grid>
</Window>
